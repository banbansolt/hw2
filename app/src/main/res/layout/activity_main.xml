<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="28dp"
    android:background="#F4F6F9"> <View
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:layout_weight="1.2"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUIZ CHALLENGE"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        android:letterSpacing="0.05"
        android:layout_marginBottom="6dp"/>



    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/main"
        android:layout_marginBottom="40dp"
        android:contentDescription="앱 로고"/>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="0.3"/>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="게임 시작"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="#2A5C91"
        app:cornerRadius="14dp"
        android:layout_marginBottom="12dp"
        android:elevation="4dp"/>

    <Button
        android:id="@+id/btnRanking"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="랭킹 보기"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="#4A90E2"
        app:cornerRadius="14dp"
        android:layout_marginBottom="12dp"
        android:elevation="2dp"/>

    <Button
        android:id="@+id/btnInfo"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text=" 앱 정보 확인"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="#10B981"
        app:cornerRadius="14dp"
        android:layout_marginBottom="12dp"
        android:elevation="2dp"/>

    <Button
        android:id="@+id/btnExit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="종료하기"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="#F43F5E"
        app:cornerRadius="14dp"
        android:elevation="2dp"/>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>